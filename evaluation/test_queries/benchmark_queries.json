  "evaluation_metrics": {
    "precision_at_k": [5, 10, 20],
    "recall_at_k": [10, 20],
    "ndcg_at_k": [10],
    "mean_reciprocal_rank": true,
    "user_satisfaction": {
      "scale": "1-5",
      "dimensions": ["relevance", "ordering", "explanation_quality"]
    }
  },
  "ground_truth_notes": "Ground truth relevance judgments to be collected through:\n1. Expert annotation (2-3 domain experts)\n2. User study participants (n=15-20)\n3. Inter-annotator agreement via Krippendorff's alpha"
