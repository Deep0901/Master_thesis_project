# Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (optional - for LLM query normalization)
# OPENAI_API_KEY=sk-your-api-key-here

# CKAN API Configuration
# CKAN_BASE_URL=https://opendata.swiss/api/3

# Feature Flags
# DEBUG_MODE=false
# ENABLE_LLM=false

# Fuzzy System Configuration
# DEFUZZ_METHOD=centroid
